<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Analyse préfixes ADIF</title>
<style>
body { background:#111; color:#eee; font-family:Arial; padding:20px; }
textarea { width:100%; height:200px; background:#222; color:#0f0; border:1px solid #444; padding:10px; }
button { padding:10px; background:#007bff; border:none; color:white; cursor:pointer; margin-top:10px; }
button:hover { background:#0a84ff; }
pre { background:#222; padding:10px; border:1px solid #444; }
</style>
</head>
<body>

<h2>Analyse automatique des préfixes ADIF</h2>

<input type="file" id="file" accept=".adi,.adif"><br><br>
<button onclick="analyze()">Analyser</button>

<h3>Préfixes détectés :</h3>
<pre id="output"></pre>

<script>
function analyze() {
    const file = document.getElementById("file").files[0];
    if (!file) { alert("Choisis un fichier ADIF"); return; }

    file.text().then(text => {
        const regex = /<call[^>]*>\s*([^<\s]+)/gi;
        let match;
        const prefixes = new Set();

        while ((match = regex.exec(text)) !== null) {
            const call = match[1].trim().toUpperCase();

            // Préfixe = 1 à 3 premiers caractères alphabétiques
            const p = call.match(/^[A-Z0-9]{1,3}/);
            if (p) prefixes.add(p[0]);
        }

        document.getElementById("output").textContent =
            Array.from(prefixes).sort().join("\n");
    });
}
</script>

</body>
</html>
